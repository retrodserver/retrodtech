<IfModule mod_rewrite.c>
RewriteEngine On

# Force HTTPS (safe version)
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove www (safe version)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# BLOG SLUG ROUTE (place before generic rules)
RewriteRule ^blog/([^/]+)/?$ ExpBlog.php?slug=$1 [L,QSA]

# Redirect .php to extensionless (only direct request)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# add X-Robots-Tag header for sensitive directories
<IfModule mod_headers.c>
    <Location /admin>
        Header set X-Robots-Tag "noindex, nofollow"
    </Location>
    <Location /api>
        Header set X-Robots-Tag "noindex, nofollow"
    </Location>
    <Location /screen>
        Header set X-Robots-Tag "noindex, nofollow"
    </Location>
</IfModule>

# Rewrite extensionless to .php if file exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

</IfModule>