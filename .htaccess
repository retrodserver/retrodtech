<IfModule mod_rewrite.c>
RewriteEngine On

# Force HTTPS (safe version)
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove www (safe version)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# BLOG SLUG ROUTE (place before generic rules)
RewriteRule ^blog/([^/]+)/?$ ExpBlog.php?slug=$1 [L,QSA]

# Redirect .php to extensionless (only direct request)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# Rewrite extensionless to .php if file exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

</IfModule>